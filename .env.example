# Gerado automaticamente pelo bootstrap.sh em workbenches/<nome>/.env
# Se quiser criar manualmente:
#   ssh-keygen -t ed25519 -f ~/.ssh/<nome> -N ""
#   # cole o conteúdo de ~/.ssh/<nome>.pub abaixo:
INSTANCE_NAME=<nome>
SSH_PORT=2222
AUTHORIZED_KEY=ssh-ed25519 AAAA...sua-chave-publica-aqui... <nome>@seu-mac
